# .env.example - copy to .env and fill in values

# API Authentication
API_KEY_EXAMPLES=supersecretkey123,testkey456

# App Info
APP_NAME=EchoAPI

# CORS — set to your frontend domain(s) in production (comma-separated)
# Example: CORS_ORIGINS=https://myapp.com,https://www.myapp.com
CORS_ORIGINS=*

# Port — Railway sets this automatically; override here if running locally on a different port
PORT=8000

# Supabase (get from supabase.com → Project Settings → API)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Upstash Redis (get from upstash.com → Redis → REST API)
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token
